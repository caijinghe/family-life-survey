rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 默认拒绝所有
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // 允许已登录（包含匿名）的用户上传到自己的路径
    // 路径格式: recordings/{respondentId}/{fileName}
    match /recordings/{respondentId}/{fileName} {
      // 允许匿名用户创建（上传）
      // 这里的 respondentId 是应用生成的，只要是已登录用户即可上传
      allow create: if request.auth != null;
      
      // 仅允许极高权限或内部流程读取（这里为了安全默认设为 false）
      // 如果你想在后台看，通常是通过 Firebase 控制台直接看，不需要在这里打开 read
      allow read: if false;
    }
  }
}
