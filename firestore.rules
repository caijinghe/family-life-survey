rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      // Simplified regex to be more robust with dashes/underscores
      return id is string && id.size() <= 128;
    }

    // --- Entity Validations ---

    function isValidResponse(data) {
      // Only require the core respondent identity and a timestamp
      return data.respondent_id is string && 
             data.submitted_at is timestamp;
    }

    function isValidRecording(data) {
      return data.respondent_id is string && 
             data.q_id is string &&
             data.created_at is timestamp;
    }

    // --- Collection Rules ---

    match /_health_check/{docId} {
      allow read: if true;
    }

    match /responses/{responseId} {
      // Allow any create/update as long as it's for their own ID
      allow create, update: if isValidId(responseId) && 
                               incoming().respondent_id == responseId && 
                               isValidResponse(incoming());
      allow read: if true;
    }

    match /recordings/{recordingId} {
      allow create, update: if isValidId(recordingId) && 
                               isValidRecording(incoming());
      allow read: if true;
    }
  }
}
