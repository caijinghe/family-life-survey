{
  "entities": {
    "Response": {
      "title": "Survey Response",
      "description": "Final submitted survey response metadata",
      "type": "object",
      "properties": {
        "respondent_id": { "type": "string" },
        "submitted_at": { "type": "string", "format": "date-time" },
        "follow_up_email": { "type": "string" },
        "structured_answers": { "type": "object" },
        "voice_urls": { "type": "object" },
        "voice_transcripts": { "type": "object" },
        "voice_questions_reference": { "type": "object" }
      },
      "required": ["respondent_id", "submitted_at"]
    },
    "Recording": {
      "title": "Voice Recording",
      "description": "Individual question voice recording data and transcript",
      "type": "object",
      "properties": {
        "respondent_id": { "type": "string" },
        "q_id": { "type": "string" },
        "transcript": { "type": "string" },
        "audio_data": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["respondent_id", "q_id", "transcript", "created_at"]
    }
  },
  "firestore": {
    "/responses/{responseId}": {
      "schema": "Response",
      "description": "Collection of final survey responses"
    },
    "/recordings/{recordingId}": {
      "schema": "Recording",
      "description": "Collection of individual voice recordings"
    }
  }
}
